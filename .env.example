# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=

# Discord Server (Guild) ID
DISCORD_GUILD_ID=

# Comma-separated Discord User IDs allowed to use the bot
ALLOWED_USER_IDS=

# Data directory (default: ~/.rrai) — database, sessions, lock file
# RRAI_DATA_DIR=~/.rrai

# Max messages per user per minute (default: 10)
RATE_LIMIT_PER_MINUTE=10

# Optional: Channel ID for session status change notifications
# STATUS_CHANNEL_ID=

# Optional: Operational tuning
# EDIT_INTERVAL_MS=1500          # Discord message edit throttle (ms)
# APPROVAL_TIMEOUT_SECS=300      # Tool approval timeout (seconds)
# MAX_QUEUE_SIZE=5                # Max queued messages per channel
# SDK_CALL_TIMEOUT_SECS=15       # SDK control command timeout (seconds)
